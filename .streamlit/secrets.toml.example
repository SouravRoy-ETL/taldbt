# taldbt — LLM Configuration (EXAMPLE)
# ─────────────────────────────────────
# Copy to .streamlit/secrets.toml and fill in your keys.
# Auto-detection: Ollama (local) → Cerebras → Groq → OpenRouter
# Just set keys — taldbt picks the best provider automatically.

[llm]
# Primary provider. Options: cerebras, groq, openrouter, together, custom
provider = "cerebras"
api_key = "csk-your-cerebras-key-here"
model = "qwen-3-235b-a22b-instruct-2507"

# ── Fallback providers (optional, auto-discovered) ──
# If primary hits rate limits, taldbt falls back to these automatically.

# [groq]
# api_key = "gsk_your_groq_key"

# [openrouter]
# api_key = "sk-or-your_key"

# ── Custom OpenAI-compatible endpoint ──
# [llm]
# provider = "custom"
# base_url = "https://your-endpoint.com/v1"
# api_key = "your-key"
# model = "your-model"
